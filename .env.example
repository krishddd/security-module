# ============================================================================
#  Template — copy to .env and fill in real values.  Never commit .env.
# ============================================================================
#
# python-dotenv loads .env at CLI startup.
#
# ANTHROPIC_API_KEY  -> required for --llm (planner / synthesizer / triager).
# OPENAI_API_KEY     -> reserved for a future OpenAI provider; no effect today.
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# ASI_LLM_MODEL_PLANNER=claude-opus-4-7
# ASI_LLM_MODEL_PAYLOAD=claude-sonnet-4-6
# ASI_LLM_MODEL_TRIAGE=claude-sonnet-4-6
# ASI_MAX_LLM_SPEND_USD=2.00
# ASI_MAX_LLM_CALLS=200

# Auth tokens for agents under test (refer to by name via --auth-env)
# MY_AGENT_TOKEN=
