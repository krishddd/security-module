{
  "_comment": "Odysseus -- self-hosted autonomous AI workspace (39k+ GitHub stars). FastAPI + MCP-based. Multi-service docker compose. Default port 7000. To scan: set ODYSSEUS_TOKEN env var to an API token generated in the admin UI, then run scan-v3. The script tries /openapi.json auto-discover first and falls back to this hand-crafted profile if needed.",
  "schema_version": "3.0",
  "name": "odysseus_local",
  "agent_id": "",
  "base_url": "http://127.0.0.1:7000",
  "transport": "rest",
  "auth": {
    "scheme": "bearer",
    "token_env_var": "ODYSSEUS_TOKEN",
    "header_name": "Authorization",
    "header_prefix": "Bearer ",
    "refresh_endpoint": null
  },
  "endpoints": [
    {"path": "/api/health",          "method": "GET",  "purpose": "health",       "auth_required": false, "tags": ["health"],          "operation_id": "health"},
    {"path": "/openapi.json",        "method": "GET",  "purpose": "memory_read",  "auth_required": false, "tags": ["meta"],            "operation_id": "openapi"},
    {"path": "/api/auth/login",      "method": "POST", "purpose": "auth",         "auth_required": false, "tags": ["auth"],            "operation_id": "login"},
    {"path": "/api/auth/me",         "method": "GET",  "purpose": "auth",         "auth_required": true,  "tags": ["auth"],            "operation_id": "me"},
    {"path": "/api/auth/tokens",     "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["auth","tokens"],   "operation_id": "list_tokens"},
    {"path": "/api/auth/tokens",     "method": "POST", "purpose": "auth",         "auth_required": true,  "tags": ["auth","tokens"],   "operation_id": "create_token"},
    {"path": "/api/v1/chat",         "method": "POST", "purpose": "chat",         "auth_required": true,  "tags": ["chat"],            "operation_id": "sync_chat",
     "summary": "Synchronous chat (preferred for security probes — returns complete reply)",
     "request_schema": {"type": "object", "properties": {"message": {"type": "string"}, "model": {"type": "string"}, "session": {"type": "string"}}, "required": ["message"]}},
    {"path": "/api/chat",            "method": "POST", "purpose": "chat",         "auth_required": true,  "tags": ["chat"],            "operation_id": "chat",
     "request_schema": {"type": "object", "properties": {"message": {"type": "string"}, "session": {"type": "string"}, "use_web": {"type": "boolean"}}, "required": ["message"]}},
    {"path": "/api/chat_stream",     "method": "POST", "purpose": "chat",         "auth_required": true,  "tags": ["chat","stream"],   "operation_id": "chat_stream"},
    {"path": "/api/chat/sessions",   "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["chat","sessions"], "operation_id": "list_sessions"},
    {"path": "/api/chat/sessions/{id}","method": "GET","purpose": "memory_read",  "auth_required": true,  "tags": ["chat","sessions"], "operation_id": "get_session"},
    {"path": "/api/chat/sessions/{id}","method": "DELETE","purpose": "memory_write","auth_required": true, "tags": ["chat","sessions"],"operation_id": "delete_session"},
    {"path": "/api/agent/run",       "method": "POST", "purpose": "tool_invoke",  "auth_required": true,  "tags": ["agent","run"],     "operation_id": "agent_run",
     "summary": "Run autonomous agent task (shell + file + web + MCP tools)"},
    {"path": "/api/agent/tools",     "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["agent","tools"],   "operation_id": "list_agent_tools"},
    {"path": "/api/skills",          "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["skills"],          "operation_id": "list_skills"},
    {"path": "/api/skills",          "method": "POST", "purpose": "memory_write", "auth_required": true,  "tags": ["skills"],          "operation_id": "create_skill",
     "summary": "Create custom skill / tool (supply chain risk)"},
    {"path": "/api/files",           "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["files"],           "operation_id": "list_files"},
    {"path": "/api/files/upload",    "method": "POST", "purpose": "file_io",      "auth_required": true,  "tags": ["files","upload"],  "operation_id": "upload_file"},
    {"path": "/api/files/{path}",    "method": "GET",  "purpose": "file_io",      "auth_required": true,  "tags": ["files","read"],    "operation_id": "read_file"},
    {"path": "/api/files/{path}",    "method": "DELETE","purpose": "file_io",     "auth_required": true,  "tags": ["files"],           "operation_id": "delete_file"},
    {"path": "/api/shell/exec",      "method": "POST", "purpose": "code_exec",    "auth_required": true,  "tags": ["shell","exec"],    "operation_id": "shell_exec",
     "summary": "Execute shell command via agent"},
    {"path": "/api/mcp/servers",     "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["mcp"],             "operation_id": "list_mcp_servers"},
    {"path": "/api/mcp/servers",     "method": "POST", "purpose": "memory_write", "auth_required": true,  "tags": ["mcp"],             "operation_id": "register_mcp_server",
     "summary": "Register a new MCP server (tool poisoning vector)"},
    {"path": "/api/mcp/tools",       "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["mcp","tools"],     "operation_id": "list_mcp_tools"},
    {"path": "/api/memory",          "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["memory"],          "operation_id": "list_memory"},
    {"path": "/api/memory",          "method": "POST", "purpose": "memory_write", "auth_required": true,  "tags": ["memory"],          "operation_id": "write_memory"},
    {"path": "/api/web/search",      "method": "POST", "purpose": "tool_invoke",  "auth_required": true,  "tags": ["web","search"],    "operation_id": "web_search"},
    {"path": "/api/web/fetch",       "method": "POST", "purpose": "tool_invoke",  "auth_required": true,  "tags": ["web","fetch"],     "operation_id": "web_fetch",
     "summary": "Fetch arbitrary URL (SSRF vector)"},
    {"path": "/api/admin/users",     "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["admin"],           "operation_id": "list_users"},
    {"path": "/api/admin/settings",  "method": "GET",  "purpose": "memory_read",  "auth_required": true,  "tags": ["admin"],           "operation_id": "get_settings"}
  ],
  "tools": [
    {"name": "agent_run",         "description": "Autonomous agent execution with full tool access (shell + files + web + MCP)", "parameters": {"task": "str"}, "inferred_capability": "code_execution"},
    {"name": "shell_exec",        "description": "Direct shell command execution",                     "parameters": {"cmd": "str"},   "inferred_capability": "shell_exec"},
    {"name": "upload_file",       "description": "Upload arbitrary file",                              "parameters": {"file": "binary"}, "inferred_capability": "file_write"},
    {"name": "read_file",         "description": "Read file from workspace",                           "parameters": {"path": "str"},  "inferred_capability": "file_read"},
    {"name": "web_fetch",         "description": "Fetch arbitrary URL (SSRF vector)",                  "parameters": {"url": "str"},   "inferred_capability": "web_browse"},
    {"name": "create_skill",      "description": "Inject custom skill / tool definition",              "parameters": {"name": "str"},  "inferred_capability": "tool_invoke"},
    {"name": "register_mcp_server","description": "Register MCP server (tool poisoning vector)",       "parameters": {"url": "str"},   "inferred_capability": "tool_invoke"},
    {"name": "sync_chat",         "description": "Synchronous chat — single message in, single reply out",  "parameters": {"message": "str"}, "inferred_capability": "tool_invoke"}
  ],
  "inferred_capabilities": [
    "code_execution", "shell_exec", "file_read", "file_write", "tool_invoke",
    "memory_persist", "web_browse", "subagent_dispatch", "sql_query", "email_send"
  ],
  "data_domains": [],
  "risk_tier": "critical",
  "risk_tier_source": "user",
  "rate_limit": {"requests_per_minute": 60, "burst": 10, "max_retries_on_429": 3},
  "notes": "Odysseus has explicit shell + file + MCP tool surface. Expected findings: ASI05 (code exec) and EXT08 (sandbox isolation) should fire HARD vs AnythingLLM. Compare side-by-side: AnythingLLM had no code-exec category; Odysseus has it as a core feature."
}
