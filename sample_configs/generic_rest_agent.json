{
  "schema_version": "3.0",
  "name": "generic_rest_agent",
  "agent_id": "",
  "base_url": "https://your-agent.example.com",
  "transport": "rest",
  "auth": {
    "scheme": "bearer",
    "token_env_var": "MY_AGENT_TOKEN",
    "header_name": "Authorization",
    "header_prefix": "Bearer ",
    "refresh_endpoint": null
  },
  "endpoints": [
    {
      "path": "/chat",
      "method": "POST",
      "purpose": "chat",
      "request_schema": {"type": "object", "properties": {"question": {"type": "string"}}},
      "response_schema": null,
      "auth_required": true,
      "tags": ["chat"],
      "operation_id": "chat",
      "summary": "Primary conversational endpoint"
    },
    {
      "path": "/healthz",
      "method": "GET",
      "purpose": "health",
      "request_schema": null,
      "response_schema": null,
      "auth_required": false,
      "tags": ["health"],
      "operation_id": "healthz",
      "summary": "Liveness probe"
    },
    {
      "path": "/tools/invoke",
      "method": "POST",
      "purpose": "tool_invoke",
      "request_schema": {
        "type": "object",
        "properties": {
          "tool": {"type": "string"},
          "args": {"type": "object"}
        }
      },
      "response_schema": null,
      "auth_required": true,
      "tags": ["tools"],
      "operation_id": "invoke_tool",
      "summary": "Generic tool dispatcher"
    }
  ],
  "tools": [],
  "inferred_capabilities": ["tool_invoke"],
  "data_domains": [],
  "risk_tier": "medium",
  "risk_tier_source": "user",
  "rate_limit": {
    "requests_per_minute": 60,
    "burst": 10,
    "max_retries_on_429": 3
  },
  "notes": "Hand-edited starter profile. Replace endpoints/capabilities to match your agent, or run `cli.py discover --url ... --openapi-url ... --out profile.json` to generate one automatically."
}
